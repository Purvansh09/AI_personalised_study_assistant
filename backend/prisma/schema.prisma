// Prisma schema for AI-Powered Study Assistant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User account model
model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  // Relations
  learningProfile LearningProfile?
  chatSessions    ChatSession[]
  topics          Topic[]
  quizResults     QuizResult[]
  documents       Document[]
}

// Learning style profile for personalization
model LearningProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  learningStyle String   // visual, auditory, kinesthetic, reading_writing
  preferences   String   // Additional preferences as JSON (stored as string)
  quizAnswers   String?  // Store quiz answers for reference (stored as string)
  lastUpdated   DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Chat session container
model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

// Individual chat messages
model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // 'user' or 'assistant'
  content   String
  timestamp DateTime @default(now())
  
  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Topics studied by user
model Topic {
  id           String       @id @default(cuid())
  userId       String
  topicName    String
  masteryLevel Int          @default(0) // 0-100
  lastStudied  DateTime     @default(now())
  createdAt    DateTime     @default(now())
  
  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizResults QuizResult[]
  
  @@unique([userId, topicName])
}

// Quiz results for progress tracking
model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  topicId   String?
  score     Int      // 0-100
  totalQuestions Int
  correctAnswers Int
  timestamp DateTime @default(now())
  
  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
}

// Uploaded study documents
model Document {
  id           String   @id @default(cuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  textContent  String   // Extracted text content
  uploadedAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
